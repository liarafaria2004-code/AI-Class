# Gemini
GEMINI_API_KEY=your-gemini-api-key

# Database
DATABASE_URL=sqlite:///./notes.db

# Application settings
APP_ENV=development
APP_NAME=AI-Class
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
API_KEY=change-me
ENABLE_API_KEY_AUTH=false
RATE_LIMIT_PER_MINUTE=60
LOG_LEVEL=INFO
TELEMETRY_ENABLED=true
